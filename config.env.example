# ===== Voice Agent Config =====

# Typhoon local backend
TYPHOON_MODEL="scb10x/typhoon-asr-realtime"
TYPHOON_DEVICE="auto"
TYPHOON_CPU_THREADS="16"
TYPHOON_VENV="./.venv"
TYPHOON_HF_HOME="./.cache/huggingface"
TYPHOON_PROFILE_DEFAULT="smart"
TYPHOON_REQUEST_TIMEOUT="120"
TYPHOON_STARTUP_TIMEOUT="180"
TYPHOON_FFMPEG_TIMEOUT="30"
TYPHOON_REPLACEMENTS_FILE="./typhoon_replacements.tsv"

# Recording settings
REC_SECONDS_DEFAULT=8
AUDIO_WAV="/tmp/voice_agent.wav"
ARECORD_FORMAT="S16_LE"
ARECORD_CHANNELS="1"
ARECORD_RATE="16000"

# Typing delay (ms per char-ish, only for xdotool fallback)
TYPE_DELAY=6

# Optional: ALSA device override (leave empty to use system default)
# Find devices with: arecord -L
ARECORD_DEVICE=""

# UI Settings
POPUP_ENABLED=true
